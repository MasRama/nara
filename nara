var fs = require("fs");

(async ()=>{
    
    const natives = fs.readdirSync("./commands/native").filter(f => f.endsWith(".ts") || f.endsWith(".js"));
    
    if(natives.length)
    {
        const { spawn } = require("child_process");

        const args = process.argv.slice(2);

        const proc = spawn("npx", ["tsx", "./commands/index.ts"].concat(args), { stdio: "inherit" });

        proc.on("exit", (code) => {
            process.exit(code ?? 0);
        });
    }
  
})()
