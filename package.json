{
  "name": "nara",
  "version": "2.0.0",
  "private": true,
  "description": "AI-first TypeScript full-stack starter kit. ultimate-express + Svelte 5 + Inertia.js + SQLite. Raw SQL, plain functions, zero ORM. Auth, RBAC, CSRF, rate limiting, structured logging, file storage, and a complete user management UI.",
  "main": "server.ts",
  "scripts": {
    "dev": "clear && rm -rf dist && rm -rf build && npx concurrently 'vite' 'sleep 1 && npx nodemon --legacy-watch'",
    "build": "vite build && tsc && tsc-alias -p tsconfig.json && cp -rf dist build && cp -rf public build",
    "start": "node build/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "npx tsc --noEmit",
    "typecheck": "npx tsc --noEmit",
    "migrate": "npx ts-node -r tsconfig-paths/register scripts/migrate.ts",
    "migrate:rollback": "npx ts-node -r tsconfig-paths/register scripts/migrate.ts --rollback",
    "migrate:status": "npx ts-node -r tsconfig-paths/register scripts/migrate.ts --status",
    "migrate:fresh": "npx ts-node -r tsconfig-paths/register scripts/migrate.ts --fresh && npx ts-node -r tsconfig-paths/register scripts/seed.ts",
    "seed": "npx ts-node -r tsconfig-paths/register scripts/seed.ts",
    "codemap": "npx ts-node scripts/codemap.ts",
    "lint:layers": "npx ts-node scripts/lint-layers.ts",
    "check:freshness": "npx ts-node scripts/check-freshness.ts",
    "check": "npm run lint && npm run lint:layers && npm test && npm run check:freshness"
  },
  "author": "MasRama",
  "license": "ISC",
  "dependencies": {
    "@inertiajs/svelte": "^3.3.1",
    "@lucide/svelte": "^1.8.0",
    "@tailwindcss/vite": "^4.3.0",
    "@zag-js/dialog": "^1.41.2",
    "@zag-js/menu": "^1.41.2",
    "@zag-js/pagination": "^1.41.2",
    "@zag-js/svelte": "^1.41.2",
    "@zag-js/switch": "^1.41.2",
    "@zag-js/tabs": "^1.41.2",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "mode-watcher": "^1.1.0",
    "multer": "^2.1.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "pino-roll": "^4.0.0",
    "sharp": "^0.34.4",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "ultimate-express": "^2.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.9",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.0.1",
    "nodemon": "^3.1.7",
    "svelte": "^5.41.3",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.4"
  }
}
