{
  "name": "nara",
  "version": "1.2.11",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "description": "Nara is a full-stack TypeScript starter kit built on ultimate-express, Svelte 5, and Inertia.js. Batteries included: auth, RBAC, CSRF, rate limiting, structured logging, CLI generators, and a complete user management UI.",
  "main": "server.ts",
  "scripts": {
    "dev": "clear && rm -rf dist && rm -rf build && npx concurrently 'vite' 'sleep 1 && npx nodemon --legacy-watch'",
    "build": "mkdir -p dist/views && cp -rf resources/views/* dist/views && vite build && tsc && tsc-alias -p tsconfig.json && cp -rf dist build && cp -rf public build",
    "start": "node build/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "npx tsc --noEmit",
    "typecheck": "npx tsc --noEmit",
    "migrate": "npx knex migrate:latest",
    "migrate:rollback": "npx knex migrate:rollback",
    "migrate:fresh": "npx knex migrate:rollback --all && npx knex migrate:latest && npx knex seed:run",
    "migrate:status": "npx knex migrate:status",
    "migrate:make": "npx knex migrate:make",
    "seed": "npx knex seed:run"
  },
  "author": "MasRama",
  "license": "ISC",
  "dependencies": {
    "@inertiajs/svelte": "^2.2.10",
    "@lucide/svelte": "^1.8.0",
    "@tailwindcss/typography": "^0.5.16",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.4.1",
    "bits-ui": "^2.18.0",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "knex": "^3.1.0",
    "mode-watcher": "^1.1.0",
    "multer": "^2.1.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "pino-roll": "^4.0.0",
    "sharp": "^0.34.4",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "ultimate-express": "^2.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.9",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "nodemon": "^3.1.7",
    "svelte": "^5.41.3",
    "tailwindcss": "^3.4.14",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.4"
  }
}
