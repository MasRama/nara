# Production Environment Template
# Copy this to .env.production on your server (DO NOT commit .env.production)

# Server
NODE_ENV=production
PORT=5555
APP_URL=https://yourdomain.com
HAS_CERTIFICATE=true

# Database
DB_FILE=database/production.sqlite3

# Logging
LOG_LEVEL=info
# LOG_PRETTY=true   # set this when you want readable colored logs while testing prod build locally


# Backup (optional)
BACKUP_ENCRYPTION_KEY=your_encryption_key
BACKUP_RETENTION_DAYS=30
