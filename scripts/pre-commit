#!/bin/sh
# Nara pre-commit hook — runs layer boundary lint.
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

echo "── Nara pre-commit check ──"

npx ts-node scripts/lint-layers.ts
if [ $? -ne 0 ]; then
  echo "❌ Layer boundary lint failed. Fix violations above."
  exit 1
fi

echo "✓ Pre-commit check passed."
exit 0
